{
  "name": "polydeukes",
  "version": "0.1.0",
  "description": "A development discipline framework for building alongside an AI coding partner — deterministic covenants, a verifiable work ledger, local memory, and adversarial verification. Pre-alpha; design stage.",
  "keywords": [
    "harness",
    "guard",
    "discipline",
    "covenant",
    "ai",
    "agent",
    "dev-tool",
    "ledger",
    "verification"
  ],
  "license": "MIT",
  "homepage": "https://github.com/huskyhoochu/polydeukes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huskyhoochu/polydeukes.git",
    "directory": "packages/polydeukes"
  },
  "bugs": {
    "url": "https://github.com/huskyhoochu/polydeukes/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@polydeukes/core": "workspace:*",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
